#!/usr/bin/env python3
import gi
gi.require_version('Gtk', '4.0')
from gi.repository import Gtk, Gdk, GLib
import subprocess

CSS = """
* { outline: none; box-shadow: none; }
window {
    background-color: rgba(20, 20, 30, 0.97);
    border-radius: 16px;
    border: 1px solid rgba(203, 166, 247, 0.25);
}
.header {
    font-size: 15px;
    font-weight: bold;
    color: #cdd6f4;
    padding: 14px 18px 6px 18px;
}
.section-label {
    font-size: 10px;
    font-weight: bold;
    color: #6c7086;
    padding: 8px 18px 4px 18px;
}
.card {
    background-color: rgba(49, 50, 68, 0.5);
    border-radius: 12px;
    margin: 2px 10px;
    padding: 12px;
}
.track-title {
    font-size: 14px;
    font-weight: bold;
    color: #cdd6f4;
}
.track-artist {
    font-size: 12px;
    color: #6c7086;
}
.vol-label {
    font-size: 12px;
    color: #cba6f7;
    font-weight: bold;
    min-width: 40px;
}
.ctrl-btn {
    background-color: rgba(203, 166, 247, 0.1);
    color: #cba6f7;
    border: 1px solid rgba(203, 166, 247, 0.25);
    border-radius: 50px;
    padding: 6px 16px;
    font-size: 16px;
    min-width: 44px;
}
.ctrl-btn-play {
    background-color: rgba(203, 166, 247, 0.25);
    color: #cba6f7;
    border: 1px solid rgba(203, 166, 247, 0.5);
    border-radius: 50px;
    padding: 6px 20px;
    font-size: 18px;
    min-width: 52px;
}
scale trough {
    background-color: rgba(49, 50, 68, 0.8);
    border-radius: 4px;
    min-height: 4px;
}
scale highlight {
    background-color: #cba6f7;
    border-radius: 4px;
}
scale slider {
    background-color: #cba6f7;
    border-radius: 50%;
    min-width: 12px;
    min-height: 12px;
}
"""

def run(cmd):
    try:
        return subprocess.check_output(cmd, stderr=subprocess.DEVNULL).decode().strip()
    except:
        return ""

def get_volume():
    out = run(['pactl', 'get-sink-volume', '@DEFAULT_SINK@'])
    try:
        return int(out.split('/')[1].strip().replace('%', ''))
    except:
        return 50

def set_volume(val):
    subprocess.Popen(['pactl', 'set-sink-volume', '@DEFAULT_SINK@', f'{int(val)}%'])

def get_muted():
    out = run(['pactl', 'get-sink-mute', '@DEFAULT_SINK@'])
    return 'yes' in out

class SoundPopup(Gtk.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app)
        self.set_title("Sound")
        self.set_default_size(320, -1)
        self.set_resizable(False)
        self.set_decorated(False)

        css = Gtk.CssProvider()
        css.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        key_ctrl = Gtk.EventControllerKey()
        key_ctrl.connect('key-pressed', self.on_key)
        self.add_controller(key_ctrl)
        self.connect('notify::is-active', self.on_focus_lost)

        self.build_ui()

    def on_key(self, ctrl, keyval, keycode, state):
        if keyval == Gdk.KEY_Escape:
            self.close()
        return False

    def on_focus_lost(self, *args):
        if not self.is_active():
            self.close()

    def build_ui(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.set_child(box)

        # Header
        hdr = Gtk.Label(label="  Sound")
        hdr.add_css_class("header")
        hdr.set_halign(Gtk.Align.START)
        box.append(hdr)

        # Volume section
        vol_lbl = Gtk.Label(label="VOLUME")
        vol_lbl.add_css_class("section-label")
        vol_lbl.set_halign(Gtk.Align.START)
        box.append(vol_lbl)

        vol_card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        vol_card.add_css_class("card")

        muted = get_muted()
        mute_icon = "󰝟" if muted else "󰕾"
        mute_btn = Gtk.Button(label=mute_icon)
        mute_btn.add_css_class("ctrl-btn")
        mute_btn.connect('clicked', self.on_mute)
        vol_card.append(mute_btn)

        self.vol_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
        self.vol_scale.set_value(get_volume())
        self.vol_scale.set_hexpand(True)
        self.vol_scale.set_draw_value(False)
        self.vol_scale.connect('value-changed', self.on_vol_change)
        vol_card.append(self.vol_scale)

        self.vol_pct = Gtk.Label(label=f"{get_volume()}%")
        self.vol_pct.add_css_class("vol-label")
        self.vol_pct.set_halign(Gtk.Align.END)
        vol_card.append(self.vol_pct)

        box.append(vol_card)

        # Now playing section
        title = run(['playerctl', 'metadata', 'title'])
        artist = run(['playerctl', 'metadata', 'artist'])
        status = run(['playerctl', 'status'])

        if title:
            np_lbl = Gtk.Label(label="NOW PLAYING")
            np_lbl.add_css_class("section-label")
            np_lbl.set_halign(Gtk.Align.START)
            box.append(np_lbl)

            np_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
            np_card.add_css_class("card")

            # Track info
            info_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            t = Gtk.Label(label=title[:35] + ("..." if len(title) > 35 else ""))
            t.add_css_class("track-title")
            t.set_halign(Gtk.Align.START)
            a = Gtk.Label(label=artist)
            a.add_css_class("track-artist")
            a.set_halign(Gtk.Align.START)
            info_box.append(t)
            info_box.append(a)
            np_card.append(info_box)

            # Controls
            ctrl = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            ctrl.set_halign(Gtk.Align.CENTER)

            prev_btn = Gtk.Button(label="󰒮")
            prev_btn.add_css_class("ctrl-btn")
            prev_btn.connect('clicked', lambda b: subprocess.Popen(['playerctl', 'previous']))
            ctrl.append(prev_btn)

            play_icon = "󰏤" if status == "Playing" else "󰐊"
            self.play_btn = Gtk.Button(label=play_icon)
            self.play_btn.add_css_class("ctrl-btn-play")
            self.play_btn.connect('clicked', self.on_play_pause)
            ctrl.append(self.play_btn)

            next_btn = Gtk.Button(label="󰒭")
            next_btn.add_css_class("ctrl-btn")
            next_btn.connect('clicked', lambda b: subprocess.Popen(['playerctl', 'next']))
            ctrl.append(next_btn)

            np_card.append(ctrl)
            box.append(np_card)

        # Bottom padding
        pad = Gtk.Box()
        pad.set_size_request(-1, 8)
        box.append(pad)

    def on_vol_change(self, scale):
        val = int(scale.get_value())
        self.vol_pct.set_label(f"{val}%")
        set_volume(val)

    def on_mute(self, btn):
        subprocess.Popen(['pactl', 'set-sink-mute', '@DEFAULT_SINK@', 'toggle'])
        self.close()

    def on_play_pause(self, btn):
        subprocess.Popen(['playerctl', 'play-pause'])
        status = run(['playerctl', 'status'])
        self.play_btn.set_label("󰏤" if status == "Playing" else "󰐊")

class App(Gtk.Application):
    def __init__(self):
        super().__init__(application_id='com.hypr.soundpopup')
    def do_activate(self):
        SoundPopup(self).present()

App().run()
